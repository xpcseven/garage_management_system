// ============================================================
// PRISMA SCHEMA — FINAL v4 (Production Ready)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  GARAGE_OWNER
  DRIVER
  USER
}

enum GarageRole {
  GARAGE_ADMIN
  DRIVER
}

enum TransportType {
  INTERNAL
  EXTERNAL
}

enum JobType {
  DELIVERY
  PASSENGERS
  CARGO
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SeatStatus {
  AVAILABLE
  RESERVED
  BOOKED
}

enum LuggageKind {
  LARGE_BAG
  MEDIUM_BAG
  SACK
  CARTON
}

enum PaymentMethod {
  CASH
  CARD
  WALLET
  ZAIN_CASH
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  TRIP_STARTED
  TRIP_COMPLETED
  PAYMENT_RECEIVED
  NEW_REVIEW
  GENERAL
}

enum DocumentType {
  LICENSE
  ID_CARD
  VEHICLE_REG
  INSURANCE
  OTHER
}

// ============================================================
// USER
// ============================================================

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  phone    String? @unique
  password String
  role     Role    @default(USER)

  avatar   String?
  isActive Boolean @default(true)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  garagesOwned  Garage[]       @relation("GarageOwner")
  memberships   GarageMember[]
  vehicles      Vehicle[]
  bookings      Booking[]
  driverProfile DriverProfile?
  reviews       Review[]       @relation("ReviewAuthor")
  notifications Notification[]
  tripsAsDriver Trip[]         @relation("TripDriver")
  jobPreferences UserJobPreference[]

  @@index([email])
  @@index([phone])
  @@index([isDeleted])
}

// تفضيلات نوع النقل عند التسجيل (صاحب كراج) — السائق يُخزَّن في DriverJob
model UserJobPreference {
  id        String   @id @default(uuid())
  userId    String
  jobType   JobType
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobType])
  @@index([userId])
}

// ============================================================
// CITY
// ============================================================

model City {
  id       String  @id @default(uuid())
  name     String  @unique
  region   String?
  isActive Boolean @default(true)

  tripsFrom Trip[]     @relation("TripFromCity")
  tripsTo   Trip[]     @relation("TripToCity")
  tripStops TripStop[]
}

// ============================================================
// GARAGE
// ============================================================

model Garage {
  id          String  @id @default(uuid())
  name        String
  description String?
  phone       String?
  address     String?
  logoUrl     String?
  isActive    Boolean @default(true)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User           @relation("GarageOwner", fields: [ownerId], references: [id])
  vehicles Vehicle[]
  members  GarageMember[]
  trips    Trip[]
  reviews  Review[]       @relation("GarageReview")

  @@index([ownerId])
  @@index([isDeleted])
}

// ============================================================
// GARAGE MEMBER
// ============================================================

model GarageMember {
  id       String     @id @default(uuid())
  userId   String
  garageId String
  role     GarageRole
  joinedAt DateTime   @default(now())

  user   User   @relation(fields: [userId], references: [id])
  garage Garage @relation(fields: [garageId], references: [id])

  @@unique([userId, garageId])
  @@index([garageId])
  @@index([userId])
}

// ============================================================
// VEHICLE
// ============================================================

model Vehicle {
  id            String        @id @default(uuid())
  brand         String
  model         String
  year          Int
  plateNumber   String        @unique
  color         String?
  totalSeats    Int
  transportType TransportType
  isActive      Boolean       @default(true)
  // اسم السائق المعيّن للمركبة عند ربطها بكراج
  driverName String?

  ownerId  String
  garageId String?

  owner     User              @relation(fields: [ownerId], references: [id])
  garage    Garage?           @relation(fields: [garageId], references: [id])
  trips     Trip[]
  documents VehicleDocument[]
  drivers   DriverVehicle[]

  @@index([ownerId])
  @@index([garageId])
}

// ============================================================
// DRIVER VEHICLE
// ============================================================

model DriverVehicle {
  id        String @id @default(uuid())
  driverId  String
  vehicleId String

  driver  DriverProfile @relation(fields: [driverId], references: [id])
  vehicle Vehicle       @relation(fields: [vehicleId], references: [id])

  @@unique([driverId, vehicleId])
  @@index([driverId])
  @@index([vehicleId])
}

// ============================================================
// VEHICLE DOCUMENT
// ============================================================

model VehicleDocument {
  id         String       @id @default(uuid())
  vehicleId  String
  type       DocumentType
  fileUrl    String
  expiresAt  DateTime?
  isVerified Boolean      @default(false)
  uploadedAt DateTime     @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
}

// ============================================================
// DRIVER PROFILE
// ============================================================

model DriverProfile {
  id           String  @id @default(uuid())
  userId       String  @unique
  isFreelancer Boolean @default(true)
  isVerified   Boolean @default(false)
  isActive     Boolean @default(true)
  bio          String?
  location     String?
  ratingAvg    Float   @default(0)

  currentLat Decimal? @db.Decimal(10, 8)
  currentLng Decimal? @db.Decimal(11, 8)

  user            User             @relation(fields: [userId], references: [id])
  jobs            DriverJob[]
  documents       DriverDocument[]
  reviews         Review[]         @relation("DriverReview")
  locationHistory DriverLocation[]
  vehicles        DriverVehicle[]

  @@index([userId])
  @@index([isVerified])
  @@index([isActive])
}

// ============================================================
// DRIVER LOCATION
// ============================================================

model DriverLocation {
  id         String   @id @default(uuid())
  driverId   String
  lat        Decimal  @db.Decimal(10, 8)
  lng        Decimal  @db.Decimal(11, 8)
  recordedAt DateTime @default(now())

  driver DriverProfile @relation(fields: [driverId], references: [id])

  @@index([driverId, recordedAt])
}

// ============================================================
// DRIVER DOCUMENT
// ============================================================

model DriverDocument {
  id         String       @id @default(uuid())
  driverId   String
  type       DocumentType
  fileUrl    String
  expiresAt  DateTime?
  isVerified Boolean      @default(false)
  uploadedAt DateTime     @default(now())

  driver DriverProfile @relation(fields: [driverId], references: [id])

  @@index([driverId])
}

// ============================================================
// DRIVER JOB
// ============================================================

model DriverJob {
  id       String  @id @default(uuid())
  driverId String
  jobType  JobType
  isActive Boolean @default(true)

  driver DriverProfile @relation(fields: [driverId], references: [id])

  @@unique([driverId, jobType])
}

// ============================================================
// TRIP
// ============================================================

model Trip {
  id         String  @id @default(uuid())
  garageId   String?
  vehicleId  String
  driverId   String
  fromCityId String
  toCityId   String

  departureTime DateTime
  arrivalTime   DateTime?

  basePrice       Decimal @db.Decimal(10, 2)
  priceMultiplier Float   @default(1.0)

  maxSeats       Int
  availableSeats Int

  transportType TransportType
  status        TripStatus @default(SCHEDULED)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle  Vehicle @relation(fields: [vehicleId], references: [id])
  garage   Garage? @relation(fields: [garageId], references: [id])
  driver   User    @relation("TripDriver", fields: [driverId], references: [id])
  fromCity City    @relation("TripFromCity", fields: [fromCityId], references: [id])
  toCity   City    @relation("TripToCity", fields: [toCityId], references: [id])

  seats    Seat[]
  bookings Booking[]
  stops    TripStop[]

  @@index([driverId])
  @@index([vehicleId])
  @@index([fromCityId])
  @@index([toCityId])
  @@index([departureTime])
  @@index([status])
}

// ============================================================
// TRIP STOPS (NEW)
// ============================================================

model TripStop {
  id     String @id @default(uuid())
  tripId String
  cityId String
  order  Int

  trip Trip @relation(fields: [tripId], references: [id])
  city City @relation(fields: [cityId], references: [id])

  @@index([tripId])
  @@index([cityId])
}

// ============================================================
// SEAT
// ============================================================

model Seat {
  id         String     @id @default(uuid())
  tripId     String
  seatNumber Int
  priceModifier Decimal @default(0.0) @db.Decimal(10, 2)
  status     SeatStatus @default(AVAILABLE)

  trip    Trip     @relation(fields: [tripId], references: [id])
  booking Booking?

  @@unique([tripId, seatNumber])
  @@index([tripId])
  @@index([status])
}

// ============================================================
// BOOKING
// ============================================================

model Booking {
  id     String @id @default(uuid())
  userId String
  tripId String
  seatId String @unique

  status BookingStatus @default(PENDING)

  priceAtBooking Decimal @db.Decimal(10, 2)

  cancelledAt        DateTime?
  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  trip    Trip     @relation(fields: [tripId], references: [id])
  seat    Seat     @relation(fields: [seatId], references: [id])
  payment Payment?
  review  Review?

  luggageItems BookingLuggageItem[]

  @@index([userId])
  @@index([tripId])
  @@index([status])
}

// أمتعة مسافر مرتبطة بالحجز — أكثر من غرض لكل حجز
model BookingLuggageItem {
  id          String      @id @default(uuid())
  bookingId   String
  kind        LuggageKind
  weightKg    Decimal?    @db.Decimal(8, 2)
  dimensions  String?
  quantity    Int         @default(1)

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

// ============================================================
// PAYMENT (IMPROVED)
// ============================================================

model Payment {
  id        String        @id @default(uuid())
  bookingId String        @unique
  amount    Decimal       @db.Decimal(10, 2)
  currency  String        @default("IQD")
  method    PaymentMethod @default(CASH)
  provider  String?
  status    PaymentStatus @default(PENDING)
  reference String?

  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([status])
}

// ============================================================
// REVIEW
// ============================================================

model Review {
  id String @id @default(uuid())

  authorId  String
  bookingId String? @unique
  driverId  String?
  garageId  String?

  rating  Int
  comment String?

  createdAt DateTime @default(now())

  author  User           @relation("ReviewAuthor", fields: [authorId], references: [id])
  booking Booking?       @relation(fields: [bookingId], references: [id])
  driver  DriverProfile? @relation("DriverReview", fields: [driverId], references: [id])
  garage  Garage?        @relation("GarageReview", fields: [garageId], references: [id])
}

// ============================================================
// NOTIFICATION (IMPROVED)
// ============================================================

model Notification {
  id     String @id @default(uuid())
  userId String
  type   NotificationType
  title  String
  body   String

  isRead Boolean  @default(false)
  readAt DateTime?

  data Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
}

// ============================================================
// AUDIT LOG (NEW — ENTERPRISE FEATURE)
// ============================================================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  data      Json?
  createdAt DateTime @default(now())
}